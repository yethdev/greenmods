{
    "name": "@modhost/workspace",
    "workspaces": [
        "./packages/*",
        "./ui"
    ],
    "scripts": {
        "fmt": "prettier --write ui packages",
        "scan:nexus:upload-permissions": "node ./scripts/scan-nexus-upload-permissions.mjs",
        "import:subnautica-one": "node ./scripts/import-subnautica-one-library.mjs",
